{
  "name": "revelation",
  "version": "1.0.7-git3",
  "dependencies": {
    "chart.js": "^4.5.1",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "ip": "^2.0.1",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.5",
    "npm-run-all": "^4.1.5",
    "reveal.js": "^6.0.0",
    "reveal.js-plugins": "^4.6.0",
    "reveal.js-remote": "github:fiforms/reveal.js-remote",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^8.0.3"
  },
  "scripts": {
    "dev": "npm-run-all --parallel watch:theme vite",
    "vite": "vite",
    "vite:serve": "vite --host",
    "watch:theme": "sass --watch css/source:css --silence-deprecation import --load-path=node_modules --load-path=node_modules/reveal.js/css/theme",
    "build:theme": "sass css/source:dist/css --silence-deprecation import --load-path=node_modules --load-path=node_modules/reveal.js/css/theme",
    "build:fonts": "node scripts/copy-fonts.js",
    "build": "npm-run-all vite:build build:theme build:fonts",
    "vite:build": "vite build",
    "make": "node scripts/make-presentation.js",
    "addimages": "node scripts/add-images.mjs",
    "llm:dump": "node scripts/dump-for-llm.js revelation_file_summary.txt",
    "postinstall": "node scripts/init-presentations.js",
    "init-presentations": "node scripts/init-presentations.js",
    "serve": "npm-run-all --parallel watch:theme vite:serve",
    "tests": "node tests/run-tests.cjs",
    "tests:generate": "node tests/run-tests.cjs --generate"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.0",
    "sass": "^1.97.3"
  }
}
